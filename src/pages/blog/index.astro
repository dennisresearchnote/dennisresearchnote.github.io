---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const PAGE_SIZE = 5;

const slugify = (value: string) =>
  value
    .trim()
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^\p{L}\p{N}-]+/gu, '');

const normalizePage = (value: string | null) => {
  const parsed = Number(value || 1);
  return Number.isFinite(parsed) && parsed > 0 ? Math.floor(parsed) : 1;
};

const getPostUrl = (post: Awaited<ReturnType<typeof getCollection<'blog'>>>[number]) => {
  const categoryPath = (post.data.category ?? []).map(slugify).join('/');
  return categoryPath ? `/blog/${categoryPath}/${post.slug}` : `/blog/${post.slug}`;
};

const currentPage = normalizePage(Astro.url.searchParams.get('page'));

const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));
const safeCurrentPage = Math.min(currentPage, totalPages);

const posts = allPosts.slice(
  (safeCurrentPage - 1) * PAGE_SIZE,
  safeCurrentPage * PAGE_SIZE
);

const recentPosts = allPosts.slice(0, 5);
---

<BaseLayout>
  <main class="main">
    <div class="page-title light-background">
      <div class="container d-lg-flex justify-content-between align-items-center">
        <h1 class="mb-2 mb-lg-0">Blog</h1>
        <nav class="breadcrumbs">
          <ol>
            <li><a href="/">Home</a></li>
            <li class="current">Blog</li>
          </ol>
        </nav>
      </div>
    </div>

    <div class="container">
      <div class="row">
        <div class="col-lg-8">
          <section id="blog-posts" class="blog-posts section">
            <div class="container">
              <div class="row gy-4">
                {posts.map((post) => (
                  <div class="col-lg-12">
                    <article>
                      <div class="post-img">
                        <img
                          src={post.data.thumbnail ?? '/images/test-thumbnail.png'}
                          alt={post.data.title}
                          class="img-fluid"
                        />
                      </div>

                      <h2 class="title">
                        <a href={getPostUrl(post)}>{post.data.title}</a>
                      </h2>

                      <div class="meta-top">
                        <ul>
                          <li class="d-flex align-items-center">
                            <i class="bi bi-person"></i>
                            <a href={getPostUrl(post)}>{post.data.author ?? 'Dennis'}</a>
                          </li>
                          <li class="d-flex align-items-center">
                            <i class="bi bi-clock"></i>
                            <a href={getPostUrl(post)}>
                              <time datetime={post.data.pubDate.toISOString()}>
                                {post.data.pubDate.toLocaleDateString('ko-KR')}
                              </time>
                            </a>
                          </li>
                          {(post.data.category?.length ?? 0) > 0 && (
                            <li class="d-flex align-items-center">
                              <i class="bi bi-folder"></i>
                              <span>{post.data.category?.join(' / ')}</span>
                            </li>
                          )}
                        </ul>
                      </div>

                      <div class="content">
                        <p>{post.data.description}</p>
                        <div class="read-more">
                          <a href={getPostUrl(post)}>Read More</a>
                        </div>
                      </div>
                    </article>
                  </div>
                ))}

                {posts.length === 0 && (
                  <div class="col-lg-12">
                    <article>
                      <div class="content">
                        <p>표시할 게시물이 없습니다.</p>
                      </div>
                    </article>
                  </div>
                )}
              </div>
            </div>
          </section>

          <section id="blog-pagination" class="blog-pagination section">
            <div class="container">
              <div class="d-flex justify-content-center">
                <ul>
                  {safeCurrentPage > 1 && (
                    <li>
                      <a href={safeCurrentPage - 1 === 1 ? '/blog' : `/blog?page=${safeCurrentPage - 1}`}>
                        <i class="bi bi-chevron-left"></i>
                      </a>
                    </li>
                  )}

                  {Array.from({ length: totalPages }, (_, i) => i + 1).map((page) => (
                    <li>
                      <a
                        href={page === 1 ? '/blog' : `/blog?page=${page}`}
                        class={page === safeCurrentPage ? 'active' : undefined}
                      >
                        {page}
                      </a>
                    </li>
                  ))}

                  {safeCurrentPage < totalPages && (
                    <li>
                      <a href={`/blog?page=${safeCurrentPage + 1}`}>
                        <i class="bi bi-chevron-right"></i>
                      </a>
                    </li>
                  )}
                </ul>
              </div>
            </div>
          </section>
        </div>

        <div class="col-lg-4 sidebar">
          <div class="widgets-container">
            <div class="recent-posts-widget widget-item">
              <h3 class="widget-title">Recent Posts</h3>

              {recentPosts.map((post) => (
                <div class="post-item">
                  <img
                    src={post.data.thumbnail ?? '/images/test-thumbnail.png'}
                    alt={post.data.title}
                    class="flex-shrink-0"
                  />
                  <div>
                    <h4><a href={getPostUrl(post)}>{post.data.title}</a></h4>
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('ko-KR')}
                    </time>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>