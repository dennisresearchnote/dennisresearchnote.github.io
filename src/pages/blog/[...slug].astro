---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const slugify = (value: string) =>
  value
    .trim()
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^\p{L}\p{N}-]+/gu, '');

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const getCategoryPathParts = (post: (typeof posts)[number]) =>
  (post.data.category ?? []).map(slugify);

const getPostUrl = (post: (typeof posts)[number]) => {
  const categoryPath = getCategoryPathParts(post).join('/');
  return categoryPath ? `/blog/${categoryPath}/${post.slug}` : `/blog/${post.slug}`;
};

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });

const buildWidgets = (targetPosts: typeof posts) => {
  const categoryCountMap = targetPosts.reduce((acc, post) => {
    const major = post.data.category?.[0]?.trim();
    if (!major) return acc;
    acc[major] = (acc[major] ?? 0) + 1;
    return acc;
  }, {} as Record<string, number>);

  const categories = Object.entries(categoryCountMap)
    .sort(([a], [b]) => a.localeCompare(b, 'ko-KR'))
    .map(([name, count]) => ({
      name,
      slug: slugify(name),
      count,
    }));

  const recentPosts = targetPosts.slice(0, 5);

  const tagCountMap = targetPosts.reduce((acc, post) => {
    for (const tag of post.data.tags ?? []) {
      const cleanTag = tag.trim();
      if (!cleanTag) continue;
      acc[cleanTag] = (acc[cleanTag] ?? 0) + 1;
    }
    return acc;
  }, {} as Record<string, number>);

  const tags = Object.entries(tagCountMap)
    .sort(([a], [b]) => a.localeCompare(b, 'ko-KR'))
    .map(([name]) => ({
      name,
      slug: slugify(name),
    }));

  return { categories, recentPosts, tags };
};

const resolveCategoryRoute = (
  requestedSegments: string[],
  allPosts: typeof posts
) => {
  const normalized = requestedSegments.map((segment) =>
    segment.trim().toLowerCase()
  );

  const exactMatches = allPosts.filter((entry) => {
    const categories = getCategoryPathParts(entry);
    return normalized.every((segment, index) => categories[index] === segment);
  });

  if (exactMatches.length > 0) {
    const labels =
      exactMatches[0]?.data.category?.slice(0, normalized.length) ?? normalized;

    return {
      resolvedPath: normalized,
      categoryLabels: labels,
      filteredPosts: exactMatches,
      pageTitle: labels.join(' / '),
    };
  }

  if (normalized.length === 1) {
    const targetSlug = normalized[0];
    const matchedParents = new Map<string, string>();

    for (const entry of allPosts) {
      const rawCategories = entry.data.category ?? [];
      const categorySlugs = rawCategories.map(slugify);

      const majorSlug = categorySlugs[0];
      const middleSlug = categorySlugs[1];
      const majorLabel = rawCategories[0];

      if (middleSlug === targetSlug && majorSlug && majorLabel) {
        matchedParents.set(majorSlug, majorLabel);
      }
    }

    if (matchedParents.size === 1) {
      const [[resolvedMajorSlug, resolvedMajorLabel]] = [...matchedParents.entries()];

      const siblingMatches = allPosts.filter((entry) => {
        const categories = getCategoryPathParts(entry);
        return categories[0] === resolvedMajorSlug;
      });

      return {
        resolvedPath: [resolvedMajorSlug],
        categoryLabels: [resolvedMajorLabel],
        filteredPosts: siblingMatches,
        pageTitle: resolvedMajorLabel,
      };
    }
  }

  return {
    resolvedPath: normalized,
    categoryLabels: requestedSegments,
    filteredPosts: [],
    pageTitle: requestedSegments.join(' / '),
  };
};

export async function getStaticPaths() {
  const slugify = (value: string) =>
    value
      .trim()
      .toLowerCase()
      .replace(/\s+/g, '-')
      .replace(/[^\p{L}\p{N}-]+/gu, '');

  const allPosts = (await getCollection('blog'))
    .filter((post) => !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  const categoryPathMap = new Map<string, string[]>();
  const postPathMap = new Map<string, (typeof allPosts)[number]>();

  for (const post of allPosts) {
    const originalCategories = post.data.category ?? [];
    const categoryParts = originalCategories.map(slugify);

    for (let i = 1; i <= categoryParts.length; i++) {
      const slugPath = categoryParts.slice(0, i).join('/');
      const labelPath = originalCategories.slice(0, i);

      if (slugPath && !categoryPathMap.has(slugPath)) {
        categoryPathMap.set(slugPath, labelPath);
      }
    }

    if (categoryParts[1] && !categoryPathMap.has(categoryParts[1])) {
      categoryPathMap.set(categoryParts[1], [originalCategories[1]]);
    }

    const fullPostPath = [...categoryParts, post.slug].join('/');
    postPathMap.set(fullPostPath, post);
  }

  const categoryPaths = [...categoryPathMap.entries()].map(([path, labels]) => ({
    params: { slug: path },
    props: {
      type: 'category',
      categoryPath: path.split('/'),
      categoryLabels: labels,
    },
  }));

  const postPaths = [...postPathMap.entries()].map(([path, post]) => ({
    params: { slug: path },
    props: {
      type: 'post',
      post,
    },
  }));

  return [...categoryPaths, ...postPaths];
}

const routeType = Astro.props.type as 'category' | 'post';

let pageTitle = 'Blog';
let categoryLabels: string[] = [];
let filteredPosts: typeof posts = [];
let post: (typeof posts)[number] | null = null;
let Content: Awaited<ReturnType<typeof render>>['Content'] | null = null;
let currentPath: string[] = [];

if (routeType === 'category') {
  const requestedPath = Astro.props.categoryPath ?? [];
  const resolved = resolveCategoryRoute(requestedPath, posts);

  currentPath = resolved.resolvedPath;
  categoryLabels = resolved.categoryLabels;
  filteredPosts = resolved.filteredPosts;
  pageTitle = resolved.pageTitle;
}

if (routeType === 'post') {
  post = Astro.props.post ?? null;

  if (!post) {
    throw new Error('Post props is missing.');
  }

  const rendered = await render(post);
  Content = rendered.Content;
  currentPath = getCategoryPathParts(post);
  categoryLabels = post.data.category ?? [];
  pageTitle = post.data.title;
}

const widgetSourcePosts = routeType === 'category' ? filteredPosts : posts;
const widgets = buildWidgets(widgetSourcePosts);
const globalWidgets = buildWidgets(posts);
---

<BaseLayout>
  <main class="main">
    <div class="page-title light-background">
      <div class="container d-lg-flex justify-content-between align-items-center">
        <h1 class="mb-2 mb-lg-0">{routeType === 'post' ? 'Blog Details' : pageTitle}</h1>
        <nav class="breadcrumbs">
          <ol>
            <li><a href="/">Home</a></li>
            <li><a href="/blog">Blog</a></li>

            {routeType === 'category' &&
              categoryLabels.map((label, index) => {
                const href = `/blog/${currentPath.slice(0, index + 1).join('/')}`;
                const isLast = index === categoryLabels.length - 1;

                return isLast ? (
                  <li class="current">{label}</li>
                ) : (
                  <li><a href={href}>{label}</a></li>
                );
              })}

            {routeType === 'post' && post && (
              <>
                {categoryLabels.map((label, index) => (
                  <li>
                    <a href={`/blog/${currentPath.slice(0, index + 1).join('/')}`}>{label}</a>
                  </li>
                ))}
                <li class="current">Blog Details</li>
              </>
            )}
          </ol>
        </nav>
      </div>
    </div>

    {routeType === 'category' && (
      <div class="container">
        <div class="row">
          <div class="col-lg-8">
            <section id="blog-posts" class="blog-posts section">
              <div class="container">
                <div class="row gy-4">
                  {filteredPosts.map((entry, index) => (
                    <div class="col-lg-12">
                      <article>
                        <div class="post-img">
                          <img
                            src={entry.data.thumbnail ?? `/assets/img/blog/blog-${(index % 4) + 1}.jpg`}
                            alt={entry.data.title}
                            class="img-fluid"
                          />
                        </div>

                        <h2 class="title">
                          <a href={getPostUrl(entry)}>{entry.data.title}</a>
                        </h2>

                        <div class="meta-top">
                          <ul>
                            <li class="d-flex align-items-center">
                              <i class="bi bi-person"></i>
                              <a href={getPostUrl(entry)}>{entry.data.author ?? 'Dennis'}</a>
                            </li>
                            <li class="d-flex align-items-center">
                              <i class="bi bi-clock"></i>
                              <a href={getPostUrl(entry)}>
                                <time datetime={entry.data.pubDate.toISOString()}>
                                  {formatDate(entry.data.pubDate)}
                                </time>
                              </a>
                            </li>
                            <li class="d-flex align-items-center">
                              <i class="bi bi-chat-dots"></i>
                              <a href={getPostUrl(entry)}>0 Comments</a>
                            </li>
                          </ul>
                        </div>

                        <div class="content">
                          <p>{entry.data.description}</p>
                          <div class="read-more">
                            <a href={getPostUrl(entry)}>Read More</a>
                          </div>
                        </div>
                      </article>
                    </div>
                  ))}

                  {filteredPosts.length === 0 && (
                    <div class="col-lg-12">
                      <article>
                        <div class="content">
                          <p>이 분류에 해당하는 게시물이 없습니다.</p>
                        </div>
                      </article>
                    </div>
                  )}
                </div>
              </div>
            </section>
          </div>

          <div class="col-lg-4 sidebar">
            <div class="widgets-container">
              <div class="search-widget widget-item">
                <h3 class="widget-title">Search</h3>
                <form action="/blog" method="get">
                  <input type="text" name="q" />
                  <button type="submit" title="Search"><i class="bi bi-search"></i></button>
                </form>
              </div>

              <div class="categories-widget widget-item">
                <h3 class="widget-title">Categories</h3>
                <ul class="mt-3">
                  {widgets.categories.map((category) => (
                    <li><a href={`/blog/${category.slug}`}>{category.name} <span>({category.count})</span></a></li>
                  ))}
                </ul>
              </div>

              <div class="recent-posts-widget widget-item">
                <h3 class="widget-title">Recent Posts</h3>

                {widgets.recentPosts.map((recent, index) => (
                  <div class="post-item">
                    <img
                      src={recent.data.thumbnail ?? `/assets/img/blog/blog-recent-${(index % 5) + 1}.jpg`}
                      alt={recent.data.title}
                      class="flex-shrink-0"
                    />
                    <div>
                      <h4><a href={getPostUrl(recent)}>{recent.data.title}</a></h4>
                      <time datetime={recent.data.pubDate.toISOString()}>
                        {formatDate(recent.data.pubDate)}
                      </time>
                    </div>
                  </div>
                ))}
              </div>

              <div class="tags-widget widget-item">
                <h3 class="widget-title">Tags</h3>
                <ul>
                  {widgets.tags.map((tag) => (
                    <li><a href="#">{tag.name}</a></li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    )}

    {routeType === 'post' && post && Content && (
      <div class="container">
        <div class="row">
          <div class="col-lg-8">
            <section id="blog-details" class="blog-details section">
              <div class="container">
                <article class="article">
                  <div class="post-img">
                    <img
                      src={post.data.thumbnail ?? '/assets/img/blog/blog-inside-post.jpg'}
                      alt={post.data.title}
                      class="img-fluid"
                    />
                  </div>

                  <h2 class="title">{post.data.title}</h2>

                  <div class="meta-top">
                    <ul>
                      <li class="d-flex align-items-center">
                        <i class="bi bi-person"></i>
                        <a href={getPostUrl(post)}>{post.data.author ?? 'Dennis'}</a>
                      </li>
                      <li class="d-flex align-items-center">
                        <i class="bi bi-clock"></i>
                        <a href={getPostUrl(post)}>
                          <time datetime={post.data.pubDate.toISOString()}>
                            {formatDate(post.data.pubDate)}
                          </time>
                        </a>
                      </li>
                      <li class="d-flex align-items-center">
                        <i class="bi bi-chat-dots"></i>
                        <a href={getPostUrl(post)}>0 Comments</a>
                      </li>
                    </ul>
                  </div>

                  <div class="content">
                    <Content />
                  </div>

                  <div class="meta-bottom">
                    <i class="bi bi-folder"></i>
                    <ul class="cats">
                      {(post.data.category ?? []).map((category, index) => (
                        <li>
                          <a href={`/blog/${currentPath.slice(0, index + 1).join('/')}`}>{category}</a>
                        </li>
                      ))}
                    </ul>

                    <i class="bi bi-tags"></i>
                    <ul class="tags">
                      {(post.data.tags ?? []).map((tag) => (
                        <li><a href="#">{tag}</a></li>
                      ))}
                    </ul>
                  </div>
                </article>
              </div>
            </section>
          </div>

          <div class="col-lg-4 sidebar">
            <div class="widgets-container">
              <div class="search-widget widget-item">
                <h3 class="widget-title">Search</h3>
                <form action="/blog" method="get">
                  <input type="text" name="q" />
                  <button type="submit" title="Search"><i class="bi bi-search"></i></button>
                </form>
              </div>

              <div class="categories-widget widget-item">
                <h3 class="widget-title">Categories</h3>
                <ul class="mt-3">
                  {globalWidgets.categories.map((category) => (
                    <li><a href={`/blog/${category.slug}`}>{category.name} <span>({category.count})</span></a></li>
                  ))}
                </ul>
              </div>

              <div class="recent-posts-widget widget-item">
                <h3 class="widget-title">Recent Posts</h3>

                {globalWidgets.recentPosts.map((recent, index) => (
                  <div class="post-item">
                    <img
                      src={recent.data.thumbnail ?? `/assets/img/blog/blog-recent-${(index % 5) + 1}.jpg`}
                      alt={recent.data.title}
                      class="flex-shrink-0"
                    />
                    <div>
                      <h4><a href={getPostUrl(recent)}>{recent.data.title}</a></h4>
                      <time datetime={recent.data.pubDate.toISOString()}>
                        {formatDate(recent.data.pubDate)}
                      </time>
                    </div>
                  </div>
                ))}
              </div>

              <div class="tags-widget widget-item">
                <h3 class="widget-title">Tags</h3>
                <ul>
                  {globalWidgets.tags.map((tag) => (
                    <li><a href="#">{tag.name}</a></li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    )}
  </main>
</BaseLayout>