---
import { getCollection } from 'astro:content';

/* Vendor CSS Files */
import '../../styles/vendor/bootstrap/css/bootstrap.min.css';
import '../../styles/vendor/bootstrap-icons/bootstrap-icons.css';
import '../../styles/vendor/aos/aos.css';
import '../../styles/vendor/swiper/swiper-bundle.min.css';

/* Main CSS File */
import '../../styles/css/main.css';

/* Vendor JS Files */
import bootstrapUrl from '../../scripts/vendor/bootstrap/js/bootstrap.bundle.min.js?url';
import validateUrl from '../../scripts/vendor/php-email-form/validate.js?url';
import aosUrl from '../../scripts/vendor/aos/aos.js?url';
import imagesloadedUrl from '../../scripts/vendor/imagesloaded/imagesloaded.pkgd.min.js?url';
import isotopeUrl from '../../scripts/vendor/isotope-layout/isotope.pkgd.min.js?url';
import purecounterUrl from '../../scripts/vendor/purecounter/purecounter_vanilla.js?url';
import waypointsUrl from '../../scripts/vendor/waypoints/noframework.waypoints.js?url';
import swiperUrl from '../../scripts/vendor/swiper/swiper-bundle.min.js?url';

/* Main JS File */
import mainUrl from '../../scripts/js/main.js?url';

const PAGE_SIZE = 5;

const slugify = (value: string) =>
  value
    .trim()
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^\p{L}\p{N}-]+/gu, '');

const normalizePage = (value: string | null) => {
  const parsed = Number(value || 1);
  return Number.isFinite(parsed) && parsed > 0 ? Math.floor(parsed) : 1;
};

const getPostUrl = (post: Awaited<ReturnType<typeof getCollection<'blog'>>>[number]) => {
  const categoryPath = (post.data.category ?? []).map(slugify).join('/');
  return categoryPath ? `/blog/${categoryPath}/${post.slug}` : `/blog/${post.slug}`;
};

const currentPage = normalizePage(Astro.url.searchParams.get('page'));

const allPosts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const navTree = new Map<string, Set<string>>();

for (const post of allPosts) {
  const categories = post.data.category ?? [];
  const major = categories[0]?.trim();
  const middle = categories[1]?.trim();

  if (!major) continue;

  if (!navTree.has(major)) {
    navTree.set(major, new Set());
  }

  if (middle) {
    navTree.get(major)?.add(middle);
  }
}

const navItems = [...navTree.entries()]
  .sort(([a], [b]) => a.localeCompare(b, 'ko-KR'))
  .map(([major, middleSet]) => ({
    major,
    majorSlug: slugify(major),
    middles: [...middleSet]
      .sort((a, b) => a.localeCompare(b, 'ko-KR'))
      .map((middle) => ({
        name: middle,
        slug: slugify(middle),
      })),
  }));

const totalPages = Math.max(1, Math.ceil(allPosts.length / PAGE_SIZE));
const safeCurrentPage = Math.min(currentPage, totalPages);

const posts = allPosts.slice(
  (safeCurrentPage - 1) * PAGE_SIZE,
  safeCurrentPage * PAGE_SIZE
);
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Blog | Dennis Research Note</title>
    <meta name="description" content="보안 연구 블로그 글 목록" />
    <meta name="keywords" content="security, malware, dfir, blog" />

    <link href="/assets/img/favicon.png" rel="icon" />
    <link href="/assets/img/apple-touch-icon.png" rel="apple-touch-icon" />

    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Raleway:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet" />
  </head>

  <body class="blog-page">
    <header id="header" class="header d-flex align-items-center sticky-top">
      <div class="container-fluid container-xl position-relative d-flex align-items-center">
        <a href="/" class="logo d-flex align-items-center me-auto">
          <h1 class="sitename">Dennis Research Note</h1>
        </a>

        <nav id="navmenu" class="navmenu">
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/blog" class="active">Blog</a></li>

            {navItems.map((item) => (
              <li class={item.middles.length > 0 ? 'dropdown' : undefined}>
                <a href={`/blog/${item.majorSlug}`}>
                  <span>{item.major}</span>
                  {item.middles.length > 0 && <i class="bi bi-chevron-down toggle-dropdown"></i>}
                </a>
                {item.middles.length > 0 && (
                  <ul>
                    {item.middles.map((middle) => (
                      <li>
                        <a href={`/blog/${item.majorSlug}/${middle.slug}`}>{middle.name}</a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
          <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
        </nav>
      </div>
    </header>

    <main class="main">
      <div class="page-title light-background">
        <div class="container d-lg-flex justify-content-between align-items-center">
          <h1 class="mb-2 mb-lg-0">Blog</h1>
          <nav class="breadcrumbs">
            <ol>
              <li><a href="/">Home</a></li>
              <li class="current">Blog</li>
            </ol>
          </nav>
        </div>
      </div>

      <div class="container">
        <div class="row">
          <div class="col-lg-8">
            <section id="blog-posts" class="blog-posts section">
              <div class="container">
                <div class="row gy-4">
                  {posts.map((post) => (
                    <div class="col-lg-12">
                      <article>
                        <div class="post-img">
                          <img src={post.data.thumbnail ?? '/images/test-thumbnail.png'} alt={post.data.title} class="img-fluid" />
                        </div>

                        <h2 class="title">
                          <a href={getPostUrl(post)}>{post.data.title}</a>
                        </h2>

                        <div class="meta-top">
                          <ul>
                            <li class="d-flex align-items-center">
                              <i class="bi bi-person"></i>
                              <a href={getPostUrl(post)}>{post.data.author ?? 'Dennis'}</a>
                            </li>
                            <li class="d-flex align-items-center">
                              <i class="bi bi-clock"></i>
                              <a href={getPostUrl(post)}>
                                <time datetime={post.data.pubDate.toISOString()}>
                                  {post.data.pubDate.toLocaleDateString('ko-KR')}
                                </time>
                              </a>
                            </li>
                            {(post.data.category?.length ?? 0) > 0 && (
                              <li class="d-flex align-items-center">
                                <i class="bi bi-folder"></i>
                                <span>{post.data.category?.join(' / ')}</span>
                              </li>
                            )}
                          </ul>
                        </div>

                        <div class="content">
                          <p>{post.data.description}</p>
                          <div class="read-more">
                            <a href={getPostUrl(post)}>Read More</a>
                          </div>
                        </div>
                      </article>
                    </div>
                  ))}

                  {posts.length === 0 && (
                    <div class="col-lg-12">
                      <article>
                        <div class="content">
                          <p>표시할 게시물이 없습니다.</p>
                        </div>
                      </article>
                    </div>
                  )}
                </div>
              </div>
            </section>

            <section id="blog-pagination" class="blog-pagination section">
              <div class="container">
                <div class="d-flex justify-content-center">
                  <ul>
                    {safeCurrentPage > 1 && (
                      <li>
                        <a href={safeCurrentPage - 1 === 1 ? '/blog' : `/blog?page=${safeCurrentPage - 1}`}>
                          <i class="bi bi-chevron-left"></i>
                        </a>
                      </li>
                    )}

                    {Array.from({ length: totalPages }, (_, index) => index + 1).map((page) => (
                      <li>
                        <a href={page === 1 ? '/blog' : `/blog?page=${page}`} class={page === safeCurrentPage ? 'active' : undefined}>
                          {page}
                        </a>
                      </li>
                    ))}

                    {safeCurrentPage < totalPages && (
                      <li>
                        <a href={`/blog?page=${safeCurrentPage + 1}`}>
                          <i class="bi bi-chevron-right"></i>
                        </a>
                      </li>
                    )}
                  </ul>
                </div>
              </div>
            </section>
          </div>

          <div class="col-lg-4 sidebar">
            <div class="widgets-container">
              <div class="blog-author-widget widget-item">
                <div class="d-flex flex-column align-items-center">
                  <img src="/images/test-thumbnail.png" class="rounded-circle flex-shrink-0" alt="Author" />
                  <h4>Dennis</h4>
                  <p>보안 연구, 악성코드 분석, 디지털 포렌식 관련 내용을 정리하는 블로그입니다.</p>
                </div>
              </div>

              <div class="categories-widget widget-item">
                <h3 class="widget-title">Categories</h3>
                <ul class="mt-3">
                  {navItems.map((item) => (
                    <li>
                      <a href={`/blog/${item.majorSlug}`}>
                        {item.major}
                        <span>({allPosts.filter((post) => (post.data.category?.[0] ?? '') === item.major).length})</span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </main>

    <script type="module" src={bootstrapUrl}></script>
    <script type="module" src={validateUrl}></script>
    <script type="module" src={aosUrl}></script>
    <script type="module" src={imagesloadedUrl}></script>
    <script type="module" src={isotopeUrl}></script>
    <script type="module" src={purecounterUrl}></script>
    <script type="module" src={waypointsUrl}></script>
    <script type="module" src={swiperUrl}></script>
    <script type="module" src={mainUrl}></script>
  </body>
</html>