---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).filter((post) => !post.data.draft);

// 대분류별 중분류 묶기
const categoryMap = posts.reduce((acc, post) => {
  const major = post.data.category?.major;
  const middle = post.data.category?.middle;

  if (!major) return acc;

  if (!acc[major]) {
    acc[major] = new Set();
  }

  if (middle) {
    acc[major].add(middle);
  }

  return acc;
}, {} as Record<string, Set<string>>);

// 정렬된 형태로 변환
const categories = Object.entries(categoryMap)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([major, middleSet]) => ({
    major,
    middles: [...middleSet].sort((a, b) => a.localeCompare(b)),
  }));
---

<header id="header" class="header d-flex align-items-center sticky-top">
  <div class="container-fluid container-xl position-relative d-flex align-items-center">

    <a href="/" class="logo d-flex align-items-center me-auto">
      <h1 class="sitename">Dennis Research Note</h1>
    </a>

    <nav id="navmenu" class="navmenu">
      <ul>
        <li><a href="/" class={Astro.url.pathname === '/' ? 'active' : ''}>Home</a></li>
        <li><a href="/about">About</a></li>

        {categories.map((category) => (
          <li class="dropdown">
            <a href={`/blog?major=${encodeURIComponent(category.major)}`}>
              <span>{category.major}</span>
              {category.middles.length > 0 && (
                <i class="bi bi-chevron-down toggle-dropdown"></i>
              )}
            </a>

            {category.middles.length > 0 && (
              <ul>
                {category.middles.map((middle) => (
                  <li>
                    <a href={`/blog?major=${encodeURIComponent(category.major)}&middle=${encodeURIComponent(middle)}`}>
                      {middle}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}

        <li><a href="/contact">Contact</a></li>
      </ul>

      <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
    </nav>

  </div>
</header>