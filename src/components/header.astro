---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).filter((post) => !post.data.draft);

const categoryMap = posts.reduce((acc, post) => {
  const categories = post.data.category ?? [];
  const major = categories[0]?.trim();
  const middle = categories[1]?.trim();

  if (!major) return acc;

  if (!acc[major]) {
    acc[major] = new Set<string>();
  }

  if (middle) {
    acc[major].add(middle);
  }

  return acc;
}, {} as Record<string, Set<string>>);

const navItems = Object.entries(categoryMap)
  .sort(([a], [b]) => a.localeCompare(b, 'ko-KR'))
  .map(([major, middleSet]) => ({
    major,
    middles: [...middleSet].sort((a, b) => a.localeCompare(b, 'ko-KR')),
  }));
---

<header id="header" class="header d-flex align-items-center sticky-top">
  <div class="container-fluid container-xl position-relative d-flex align-items-center">

    <a href="/" class="logo d-flex align-items-center me-auto">
      <h1 class="sitename">DENNIS RESEARCH NOTE</h1>
    </a>

    <nav id="navmenu" class="navmenu">
      <ul>
        <li><a href="/" class={Astro.url.pathname === '/' ? 'active' : ''}>Home</a></li>

        {navItems.map((item) => (
          <li class={item.middles.length > 0 ? 'dropdown' : undefined}>
            <a href={`/blog/${encodeURIComponent(item.major.toLowerCase())}`}>
              <span>{item.major}</span>
              {item.middles.length > 0 && <i class="bi bi-chevron-down toggle-dropdown"></i>}
            </a>

            {item.middles.length > 0 && (
              <ul>
                {item.middles.map((middle) => (
                  <li>
                    <a href={`/blog/${encodeURIComponent(item.major.toLowerCase())}/${encodeURIComponent(middle.toLowerCase())}`}>
                      {middle}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}

        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>

      <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
    </nav>

  </div>
</header>