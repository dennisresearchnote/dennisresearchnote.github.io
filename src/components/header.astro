---
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft);

// 대분류 목록
const majorCategories = [
  ...new Set(
    posts
      .map((post) => post.data.category?.major)
      .filter(Boolean)
  ),
].sort();

// 대분류별 중분류 목록
const categoryMap = majorCategories.map((major) => {
  const middleCategories = [
    ...new Set(
      posts
        .filter((post) => post.data.category?.major === major)
        .map((post) => post.data.category?.middle)
        .filter(Boolean)
    ),
  ].sort();

  return {
    major,
    middleCategories,
  };
});
---

<header id="header" class="header d-flex align-items-center sticky-top">
  <div class="container-fluid container-xl position-relative d-flex align-items-center">

    <a href="/" class="logo d-flex align-items-center me-auto">
      <h1 class="sitename">Dennis Research Note</h1>
    </a>

    <nav id="navmenu" class="navmenu">
      <ul>
        <li><a href="/" class={Astro.url.pathname === '/' ? 'active' : ''}>Home</a></li>
        <li><a href="/about">About</a></li>

        <li class="dropdown">
          <a href="/blog">
            <span>Blog</span>
            <i class="bi bi-chevron-down toggle-dropdown"></i>
          </a>

          <ul>
            <li><a href="/blog">전체 글</a></li>

            {categoryMap.map((category) => (
              <li class={category.middleCategories.length > 0 ? 'dropdown' : ''}>
                <a href={`/blog?major=${encodeURIComponent(category.major!)}`}>
                  <span>{category.major}</span>
                  {category.middleCategories.length > 0 && (
                    <i class="bi bi-chevron-down toggle-dropdown"></i>
                  )}
                </a>

                {category.middleCategories.length > 0 && (
                  <ul>
                    <li>
                      <a href={`/blog?major=${encodeURIComponent(category.major!)}`}>
                        전체
                      </a>
                    </li>

                    {category.middleCategories.map((middle) => (
                      <li>
                        <a
                          href={`/blog?major=${encodeURIComponent(category.major!)}&middle=${encodeURIComponent(middle!)}`}
                        >
                          {middle}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </li>
            ))}
          </ul>
        </li>

        <li><a href="/contact">Contact</a></li>
      </ul>

      <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
    </nav>

    <a class="btn-getstarted" href="/about">Get Started</a>

  </div>
</header>