---
import { getCollection } from 'astro:content';

const slugify = (value: string) =>
  value
    .trim()
    .toLowerCase()
    .replace(/\s+/g, '-')
    .replace(/[^\p{L}\p{N}-]+/gu, '');

const posts = (await getCollection('blog')).filter((post) => !post.data.draft);

const categoryMap = posts.reduce((acc, post) => {
  const category = post.data.category ?? [];
  const major = category[0]?.trim();
  const middle = category[1]?.trim();

  if (!major) return acc;

  if (!acc[major]) {
    acc[major] = new Set<string>();
  }

  if (middle) {
    acc[major].add(middle);
  }

  return acc;
}, {} as Record<string, Set<string>>);

const navItems = Object.entries(categoryMap)
  .sort(([a], [b]) => a.localeCompare(b, 'ko-KR'))
  .map(([major, middleSet]) => ({
    major,
    majorSlug: slugify(major),
    middles: [...middleSet]
      .sort((a, b) => a.localeCompare(b, 'ko-KR'))
      .map((middle) => ({
        name: middle,
        slug: slugify(middle),
      })),
  }));

const pathname = Astro.url.pathname;
---

<header id="header" class="header d-flex align-items-center sticky-top">
  <div class="container-fluid container-xl position-relative d-flex align-items-center">

    <a href="/" class="logo d-flex align-items-center me-auto">
      <!-- Uncomment the line below if you also wish to use an image logo -->
      <!-- <img src="assets/img/logo.png" alt=""> -->
      <h1 class="sitename">Dennis Research Note</h1>
    </a>

    <nav id="navmenu" class="navmenu">
      <ul>
        <li><a href="/" class={pathname === '/' ? 'active' : undefined}>Home</a></li>

        {navItems.map((item) => {
          const majorHref = `/blog/${item.majorSlug}`;
          const isMajorActive =
            pathname === majorHref || pathname.startsWith(`${majorHref}/`);

          return (
            <li class="dropdown">
              <a href={majorHref} class={isMajorActive ? 'active' : undefined}>
                <span>{item.major}</span>
                <i class="bi bi-chevron-down toggle-dropdown"></i>
              </a>
              <ul>
                {item.middles.map((middle) => {
                  const middleHref = `/blog/${item.majorSlug}/${middle.slug}`;
                  return (
                    <li>
                      <a href={middleHref}>{middle.name}</a>
                    </li>
                  );
                })}
              </ul>
            </li>
          );
        })}
      </ul>
      <i class="mobile-nav-toggle d-xl-none bi bi-list"></i>
    </nav>

    <a class="btn-getstarted" href="/about">Get Started</a>

  </div>
</header>