---
import Header from "../components/header.astro";
import Footer from "../components/footer.astro";

/* Vendor CSS Files */
import "../styles/vendor/bootstrap/css/bootstrap.min.css";
import "../styles/vendor/bootstrap-icons/bootstrap-icons.css";
import "../styles/vendor/aos/aos.css";
import "../styles/vendor/glightbox/css/glightbox.min.css";
import "../styles/vendor/swiper/swiper-bundle.min.css";

/* Main CSS File */
import "../styles/css/main.css";

/* Markdown CSS File */
import "../styles/css/markdown.css";

/* Vendor JS Files */
import bootstrapUrl from "../scripts/vendor/bootstrap/js/bootstrap.bundle.min.js?url";
import validateUrl from "../scripts/vendor/php-email-form/validate.js?url";
import aosUrl from "../scripts/vendor/aos/aos.js?url";
import glightboxUrl from "../scripts/vendor/glightbox/js/glightbox.min.js?url";
import imagesloadedUrl from "../scripts/vendor/imagesloaded/imagesloaded.pkgd.min.js?url";
import isotopeUrl from "../scripts/vendor/isotope-layout/isotope.pkgd.min.js?url";
import purecounterUrl from "../scripts/vendor/purecounter/purecounter_vanilla.js?url";
import waypointsUrl from "../scripts/vendor/waypoints/noframework.waypoints.js?url";
import swiperUrl from "../scripts/vendor/swiper/swiper-bundle.min.js?url";

/* Main JS File */
import mainUrl from "../scripts/js/main.js?url";
---

<html lang="ko">
  <head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Dennis Reasearch Note</title>
    <meta name="description" content="" />
    <meta name="keywords" content="" />

    <!-- Favicons -->
    <link href="assets/img/favicon.png" rel="icon" />
    <link href="assets/img/apple-touch-icon.png" rel="apple-touch-icon" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
      integrity="sha512-SnH5WK+bZxgPHs44uWIX+LLJAJ9/2PkPKZ5QiAj6Ta86w+fsb2TkR4j8f/qs6J8L4A6iQ8Wf2y5pYb3GQ0Lw=="
      crossorigin="anonymous"
      referrerpolicy="no-referrer"
    />
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link href="https://fonts.gstatic.com" rel="preconnect" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100;0,300;0,400;0,500;0,700;0,900;1,100;1,300;1,400;1,500;1,700;1,900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Raleway:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
      rel="stylesheet"
    />
    <link
  rel="stylesheet"
  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
/>
  </head>

  <body class="index-page">
    <Header />

    <slot />

    <Footer />

    <!-- Scroll Top -->
    <a
      href="#"
      id="scroll-top"
      class="scroll-top d-flex align-items-center justify-content-center"
      ><i class="bi bi-arrow-up-short"></i></a
    >

    <!-- Preloader -->
    <div id="preloader"></div>

    <script is:inline src={bootstrapUrl}></script>
    <script is:inline src={validateUrl}></script>
    <script is:inline src={aosUrl}></script>
    <script is:inline src={glightboxUrl}></script>
    <script is:inline src={imagesloadedUrl}></script>
    <script is:inline src={isotopeUrl}></script>
    <script is:inline src={purecounterUrl}></script>
    <script is:inline src={waypointsUrl}></script>
    <script is:inline src={swiperUrl}></script>

    <script type="module" src={mainUrl}></script>
    <!-- main.js가 ES module이면 아래처럼 module로 -->
    <script type="module" is:inline>
      import mermaid from "https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs";

      mermaid.initialize({
        startOnLoad: false,
        securityLevel: "loose",
        theme: "default",
      });

      const runMermaid = async () => {
        const nodes = document.querySelectorAll(".mermaid");
        if (!nodes.length) return;

        try {
          await mermaid.run({ nodes });
        } catch (err) {
          console.error("Mermaid render error:", err);
        }
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", runMermaid, {
          once: true,
        });
      } else {
        runMermaid();
      }
    </script>
    <script is:inline>
  const normalizeLangLabel = (lang) => {
    if (!lang) return "Plaintext";
    const map = {
      js: "JavaScript",
      ts: "TypeScript",
      sh: "Shell",
      bash: "Shell",
      zsh: "Shell",
      shell: "Shell",
      plaintext: "Plaintext",
      text: "Plaintext",
      md: "Markdown",
      yml: "YAML",
    };
    const lowered = lang.toLowerCase();
    return map[lowered] || lowered.charAt(0).toUpperCase() + lowered.slice(1);
  };

  const detectFilenameFromNextNode = (pre) => {
    const next = pre.nextElementSibling;
    if (!next) return null;

    if (
      next.tagName === "P" &&
      next.textContent &&
      next.textContent.trim().startsWith("{:") &&
      next.textContent.includes("file=")
    ) {
      const match = next.textContent.match(/file=['"]([^'"]+)['"]/);
      if (match?.[1]) {
        next.remove();
        return match[1];
      }
    }

    return null;
  };

  const initChirpyCodeBlocks = () => {
    document.querySelectorAll(".post-content pre").forEach((pre) => {
      if (pre.closest(".code-block")) return;

      const code = pre.querySelector("code");
      if (!code) return;

      const rawLang =
        pre.getAttribute("data-language") ||
        code.getAttribute("data-language") ||
        [...pre.classList].find((c) => c.startsWith("language-"))?.replace("language-", "") ||
        [...code.classList].find((c) => c.startsWith("language-"))?.replace("language-", "") ||
        "plaintext";

      const langLabel = normalizeLangLabel(rawLang);
      const filename = detectFilenameFromNextNode(pre);

      const wrapper = document.createElement("div");
      wrapper.className = "code-block";
      if (filename) wrapper.setAttribute("data-file", filename);
      wrapper.setAttribute("data-lang", rawLang.toLowerCase());

      const header = document.createElement("div");
      header.className = "code-header";

      const start = document.createElement("span");
      start.className = "code-header-start";
      start.setAttribute("aria-hidden", "true");

      const label = document.createElement("span");
      label.className = "code-label";

      const labelIcon = document.createElement("i");
      labelIcon.className = filename ? "bi bi-file-earmark-code" : "bi bi-code-slash";
      labelIcon.setAttribute("aria-hidden", "true");

      const labelText = document.createElement("span");
      labelText.className = "code-label-text";
      labelText.textContent = filename || langLabel;

      label.appendChild(labelIcon);
      label.appendChild(labelText);

      const copyBtn = document.createElement("button");
      copyBtn.type = "button";
      copyBtn.className = "code-copy-btn";
      copyBtn.setAttribute("aria-label", "Copy code");

      const copyIcon = document.createElement("i");
      copyIcon.className = "bi bi-clipboard";
      copyIcon.setAttribute("aria-hidden", "true");
      copyBtn.appendChild(copyIcon);

      copyBtn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(code.innerText);
          copyBtn.classList.add("copied");
          copyIcon.className = "bi bi-clipboard-check";

          setTimeout(() => {
            copyBtn.classList.remove("copied");
            copyIcon.className = "bi bi-clipboard";
          }, 1500);
        } catch (e) {
          console.error(e);
        }
      });

      pre.parentNode?.insertBefore(wrapper, pre);
      wrapper.appendChild(header);
      header.appendChild(start);
      header.appendChild(label);
      header.appendChild(copyBtn);
      wrapper.appendChild(pre);
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initChirpyCodeBlocks, { once: true });
  } else {
    initChirpyCodeBlocks();
  }
</script>
<script is:inline>
  const normalizeLangLabel = (lang) => {
    if (!lang) return "Plaintext";

    const map = {
      js: "JavaScript",
      ts: "TypeScript",
      jsx: "JSX",
      tsx: "TSX",
      sh: "Shell",
      bash: "Shell",
      zsh: "Shell",
      shell: "Shell",
      plaintext: "Plaintext",
      text: "Plaintext",
      md: "Markdown",
      yml: "YAML",
      yaml: "YAML",
      py: "Python",
      html: "HTML",
      css: "CSS",
      json: "JSON",
      xml: "XML",
      sql: "SQL",
    };

    const lowered = lang.toLowerCase();
    return map[lowered] || lowered.charAt(0).toUpperCase() + lowered.slice(1);
  };

  const detectFilenameFromNextNode = (pre) => {
    const next = pre.nextElementSibling;
    if (!next) return null;

    if (
      next.tagName === "P" &&
      next.textContent &&
      next.textContent.trim().startsWith("{:") &&
      next.textContent.includes("file=")
    ) {
      const match = next.textContent.match(/file=['"]([^'"]+)['"]/);
      if (match?.[1]) {
        next.remove();
        return match[1];
      }
    }

    return null;
  };

  const initChirpyCodeBlocks = () => {
    document.querySelectorAll(".post-content pre").forEach((pre) => {
      if (pre.closest(".code-block")) return;

      const code = pre.querySelector("code");
      if (!code) return;

      const rawLang =
        pre.getAttribute("data-language") ||
        code.getAttribute("data-language") ||
        [...pre.classList].find((c) => c.startsWith("language-"))?.replace("language-", "") ||
        [...code.classList].find((c) => c.startsWith("language-"))?.replace("language-", "") ||
        "plaintext";

      const langLabel = normalizeLangLabel(rawLang);
      const filename = detectFilenameFromNextNode(pre);

      const wrapper = document.createElement("div");
      wrapper.className = "code-block";
      if (filename) wrapper.setAttribute("data-file", filename);
      wrapper.setAttribute("data-lang", rawLang.toLowerCase());

      const header = document.createElement("div");
      header.className = "code-header";

      const start = document.createElement("span");
      start.className = "code-header-start";
      start.setAttribute("aria-hidden", "true");

      const label = document.createElement("span");
      label.className = "code-label";

      const labelIcon = document.createElement("i");
      labelIcon.className = filename ? "fa-regular fa-file-code" : "fa-solid fa-code";
      labelIcon.setAttribute("aria-hidden", "true");

      const labelText = document.createElement("span");
      labelText.className = "code-label-text";
      labelText.textContent = filename || langLabel;

      label.appendChild(labelIcon);
      label.appendChild(labelText);

      const copyBtn = document.createElement("button");
      copyBtn.type = "button";
      copyBtn.className = "code-copy-btn";
      copyBtn.setAttribute("aria-label", "Copy code");

      const copyIcon = document.createElement("i");
      copyIcon.className = "fa-regular fa-copy";
      copyIcon.setAttribute("aria-hidden", "true");
      copyBtn.appendChild(copyIcon);

      copyBtn.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(code.innerText);
          copyBtn.classList.add("copied");
          copyIcon.className = "fa-solid fa-check";

          setTimeout(() => {
            copyBtn.classList.remove("copied");
            copyIcon.className = "fa-regular fa-copy";
          }, 1500);
        } catch (e) {
          console.error(e);
        }
      });

      pre.parentNode?.insertBefore(wrapper, pre);
      wrapper.appendChild(header);
      header.appendChild(start);
      header.appendChild(label);
      header.appendChild(copyBtn);
      wrapper.appendChild(pre);
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initChirpyCodeBlocks, { once: true });
  } else {
    initChirpyCodeBlocks();
  }
</script>
  </body>
</html>
